# === API (bắt buộc ít nhất một) ===
OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# Khuyến nghị: thêm Groq để transcribe + dịch nhanh, tránh 429 OpenRouter free
GROQ_API_KEY=
GROQ_TRANSLATE_MODEL=llama-3.3-70b-versatile
GROQ_WHISPER_MODEL=whisper-large-v3-turbo

# === Tốc độ Whisper (tránh GPU lỗi cublas trên Windows) ===
WHISPER_DEVICE=cpu
WHISPER_MODEL=base
TRANSCRIBE_ENGINE=auto
# TRANSCRIBE_ENGINE=groq

# === Dịch: khi OpenRouter free hết quota ===
TRANSLATE_OFFLINE_FIRST=false
# TRANSLATE_OFFLINE_FIRST=true

# === Render ===
OUTPUT_FPS=30
FINAL_RENDER_FAST=true

# === TTS (một giọng cố định — đừng đổi giữa các lần chạy) ===
EDGE_VOICE=vi-VN-HoaiMyNeural
EDGE_TTS_RATE=+0%
